# GrokBox Secrets — copy to .env and fill in values

# Speech-to-Text (AssemblyAI Streaming v3)
ASSEMBLYAI_KEY=your_assemblyai_key_here

# LLM — xAI Grok (primary)
XAI_KEY=your_xai_api_key_here

# LLM — OpenAI (optional, for GPT/o-series models)
OPENAI_API_KEY=your_openai_api_key_here

# Spotify OAuth (for playback control skill)
SPOTIPY_CLIENT_ID=your_spotify_client_id
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret
SPOTIPY_REDIRECT_URI=https://google.com/callback/

# TTS — Kokoro ONNX server on LAN
KOKORO_SERVER=http://your-tts-host:5050/tts

# Web search (Tavily)
TAVILY_API_KEY=your_tavily_api_key_here

# Image search (SerpAPI Google Images)
SERPAPI_KEY=your_serpapi_key_here
